# ============================================
# RecoverFlow / CartGain - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Never commit .env or .env.local to version control.

# Database (Supabase PostgreSQL)
# Get these from your Supabase project dashboard -> Settings -> Database
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"
# Use a separate database for test/local data so production and test records stay isolated.
TEST_DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Set APP_DATA_ENV=production in production, test/local elsewhere.
APP_DATA_ENV="development"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional - for social login)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay (Payment Gateway)
# Use test keys for development: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."

# MSG91 (SMS - Indian transactional SMS provider)
# Get from: https://control.msg91.com/app/ -> API Keys
MSG91_AUTH_KEY="your_msg91_auth_key_here"
MSG91_SENDER_ID="CARTGN"

# WhatsApp Business API (Meta Cloud API)
# Get from: https://developers.facebook.com/apps -> WhatsApp -> API Setup
WHATSAPP_BUSINESS_TOKEN="EAAx..."
WHATSAPP_PHONE_NUMBER_ID="123456789"
WHATSAPP_VERIFY_TOKEN="your-random-verify-token"

# Resend (Email - transactional email service, 100k free/mo)
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key_here"
FROM_EMAIL="noreply@cart-gain.com"
FROM_NAME="CartGain"

# Magic-link email provider for NextAuth (optional)
EMAIL_SERVER=""  # smtp://user:pass@smtp.sendgrid.net:587 (uses nodemailer)
EMAIL_FROM="noreply@recoverflow.com"

# Redis (for Bull queues / background jobs)
# Local: install Redis locally
# Production: use Upstash (https://upstash.com) or Redis Cloud
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
# REDIS_URL="redis://default:password@your-instance.upstash.io:6379"  # Use this for Upstash/Redis Cloud

# Shopify OAuth (optional - only if using Shopify integration)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_API_SCOPES="write_checkouts,read_orders,write_orders,read_customers,write_customers"

# OpenAI (for AI-powered cart recovery message generation)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Encryption (for storing API keys and secrets at rest)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="your-encryption-key-here-at-least-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Job endpoint secret (set to a random string to secure the /api/jobs/process-carts endpoint)
JOB_SECRET=""

# Cashfree Payment Gateway (optional — for payment-failure recovery)
CASHFREE_WEBHOOK_SECRET=""

# Secure link token secret (used for single-use payment/confirmation links)
# If not set, falls back to NEXTAUTH_SECRET
LINK_SECRET=""

# Monitoring alerts — email address to receive error notifications for webhooks/crons
# If not set, alerts are logged to console only.
ALERT_EMAIL=""
