// Prisma Schema for RecoverFlow
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  stores        Store[]
  campaigns     Campaign[]
  analytics     Analytics[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DataAccessLog {
  id           String   @id @default(cuid())
  actorType    String
  actorId      String?
  action       String
  resourceType String
  resourceId   String?
  purpose      String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorType, createdAt])
  @@index([resourceType, createdAt])
  @@index([purpose, createdAt])
}

model Store {
  id              String    @id @default(cuid())
  userId          String
  name            String
  platform        String    // shopify, woocommerce, magento, bigcommerce, custom
  domain          String
  currency        String    @default("USD")
  timezone        String    @default("UTC")
  isActive        Boolean   @default(true)
  webhookUrl      String?
  apiKey          String?
  apiSecret       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  carts               Cart[]
  campaigns           Campaign[]
  recoveredCarts      RecoveredCart[]
  optOuts             OptOut[]
  revenueShareEvents  RevenueShareEvent[]

  @@unique([userId, domain])
  @@index([userId])
}

model Campaign {
  id              String    @id @default(cuid())
  storeId         String
  name            String
  isActive        Boolean   @default(false)
  channels        String[]  // sms, whatsapp, email, push
  aiOptimized     Boolean   @default(true)
  discountEnabled Boolean   @default(false)
  discountType    String?   // percentage, fixed
  discountValue   Int?
  discountCode    String?
  sendDelay       Int       @default(15) // minutes
  followUpDelay   Int       @default(180) // minutes
  maxFollowUps    Int       @default(2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  messages        Message[]
  abTests         ABTest[]

  @@index([storeId])
  @@index([storeId, isActive])
}

model Cart {
  id              String    @id @default(cuid())
  storeId         String
  cartId          String    // External cart ID
  customerId      String?
  customerEmail   String?
  customerPhone   String?
  customerName    String?
  items           Json
  totalValue      Float
  currency        String    @default("USD")
  isRecovered     Boolean   @default(false)   // true ONLY when WE recovered it (attributed) — drives credit/billing/reporting
  recoveredAt     DateTime?
  recoveredVia    String?   // sms, whatsapp, email, push
  convertedAt     DateTime? // set when an order is placed for this cart (any source) — stops further messaging, NOT a credit
  abandonedAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages        Message[]
  recoveredCart   RecoveredCart?

  @@unique([storeId, cartId])
  @@index([storeId])
  @@index([storeId, isRecovered, abandonedAt])
  @@index([storeId, convertedAt, abandonedAt])
}

model Message {
  id              String    @id @default(cuid())
  cartId          String
  campaignId      String
  channel         String    // sms, whatsapp, email, push
  content         String
  status          String    @default("pending") // pending, sent, delivered, failed
  sentAt          DateTime?
  deliveredAt     DateTime?
  clickedAt       DateTime?
  convertedAt     DateTime?
  createdAt       DateTime  @default(now())

  cart            Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@index([campaignId])
}

model RecoveredCart {
  id              String    @id @default(cuid())
  storeId         String
  cartId          String    @unique
  recoveredValue  Float
  recoveredAt     DateTime  @default(now())
  channel         String
  discountUsed    Boolean   @default(false)
  discountAmount  Float     @default(0)
  netRevenue      Float
  shopifyOrderId  String?

  store             Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cart              Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade, map: "fk_cart")
  revenueShareEvent RevenueShareEvent?

  @@index([storeId])
}

model Analytics {
  id              String    @id @default(cuid())
  userId          String
  date            DateTime  @default(now())
  cartsAbandoned  Int       @default(0)
  cartsRecovered  Int       @default(0)
  revenueRecovered Float    @default(0)
  messagesSent    Int       @default(0)
  messagesDelivered Int     @default(0)
  messagesClicked Int       @default(0)
  smsCount        Int       @default(0)
  whatsappCount   Int       @default(0)
  emailCount      Int       @default(0)
  pushCount       Int       @default(0)

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model ABTest {
  id              String    @id @default(cuid())
  campaignId      String
  name            String
  variantA        Json      // Configuration for variant A
  variantB        Json      // Configuration for variant B
  winner          String?   // A or B
  isCompleted     Boolean   @default(false)
  createdAt       DateTime  @default(now())

  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  customerId      String    // Razorpay/Stripe customer ID
  subscriptionId  String?   // Razorpay/Stripe subscription ID
  plan            String    // free, starter, pro, enterprise
  status          String    @default("active")
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  smsCredits      Int       @default(100)
  smsCreditsUsed  Int       @default(0)
  revenueShareAccrued  Float @default(0)  // Rev share accrued in current period
  revenueSharePaid     Float @default(0)  // Total rev share paid over lifetime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices            Invoice[]
  revenueShareEvents  RevenueShareEvent[]

  @@index([userId])
}

model Invoice {
  id                  String    @id @default(cuid())
  userId              String
  subscriptionId      String
  amount              Float
  status              String    @default("pending") // pending, paid, overdue, cancelled
  periodStart         DateTime
  periodEnd           DateTime
  dueDate             DateTime
  paidAt              DateTime?
  paidVia             String?   // razorpay, manual
  paymentRef          String?   // Razorpay payment ID
  razorpayOrderId     String?   // Razorpay order ID for rev-share payment
  razorpayPaymentLinkId String? // Razorpay payment link ID
  paymentLinkUrl      String?   // Short URL sent to merchant
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscription        Subscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  revenueShareEvents  RevenueShareEvent[]

  @@index([subscriptionId])
  @@index([userId])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentLinkId])
}

model RevenueShareEvent {
  id                  String    @id @default(cuid())
  subscriptionId      String
  cartId              String    @unique // one event per recovered cart — idempotency guard
  storeId             String
  shopifyOrderId      String?
  grossAmount         Float     // recoveredValue (order total before CartGain discount)
  discountAmount      Float     @default(0)
  netAmount           Float     // grossAmount - discountAmount (rev share base)
  revSharePercent     Float     // rate locked at event time
  revShareAmount      Float     // netAmount × revSharePercent / 100
  channel             String
  attributedMessageId String?
  recoveredAt         DateTime
  invoiceId           String?   // null = pending billing; set when invoiced
  createdAt           DateTime  @default(now())

  subscription  Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  recoveredCart RecoveredCart @relation(fields: [cartId], references: [cartId])
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])

  @@index([subscriptionId])
  @@index([subscriptionId, invoiceId])
  @@index([storeId])
  @@index([invoiceId])
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String   @unique
  permissions String[]
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model OptOut {
  id          String   @id @default(cuid())
  storeId     String
  email       String?
  phone       String?
  reason      String?
  optedOutAt  DateTime @default(now())

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@unique([storeId, phone])
  @@index([storeId])
}
